Method.ОписаниеОбъектаМетаданныхДляРедактораMonaco.Comment.Если\ ИмяМетаданных(ПолноеИмя)\ \=\ "ПланСчетов"\ Тогда\nЗапрос\ \=\ Новый\ Запрос(\n"ВЫБРАТЬ\n|\tПланСчетов\.Код\ КАК\ Код,\n|\tПланСчетов\.ИмяПредопределенныхДанных\ КАК\ Имя\n|ИЗ\n|\t&Таблица\ КАК\ ПланСчетов\n|ГДЕ\n|\tПланСчетов\.Предопределенный");\nЗапрос\.Текст\ \=\ СтрЗаменить(Запрос\.Текст,\ "&Таблица",\ ПолноеИмя);\nВыборка\ \=\ Запрос\.Выполнить()\.Выбрать();\nПока\ Выборка\.Следующий()\ Цикл\nОписаниеПредопределенных\.Вставить(Выборка\.Имя,\ СтрШаблон("%1\ (%2)",\ Выборка\.Имя,\ Выборка\.Код));\nКонецЦикла;\nИначе.Description=If MetadataName(FullName) \= "ChartOfAccounts" Then\nQuery \= New Query(\n"SELECT\n|\tChartOfAccounts.Code AS Code,\n|\tChartOfAccounts.PredefinedDataName AS Name\n|FROM\n|\t&Table AS ChartOfAccounts\n|WHERE\n|\tChartOfAccounts.Predefined");\nQuery.Text \= StrReplace(Query.Text, "&Table", FullName);\nSelection \= Query.Execute().Select();\nWhile Selection.Next() Do\nPredefinedDescription.Insert(Selection.Name, StrTemplate("%1 (%2)", Selection.Name, Selection.Code));\nEndDo;\nElse
Method.ОписаниеОбъектаМетаданныхДляРедактораMonaco.Comment.ЗаполнитьТипРегистра(ДополнительныеСвойства,\ ОбъектМетаданных,\ ПолноеИмя);.Description=FillRegisterType(AdditionalProperties, MetadataObject, FullName);
Method.ОписаниеОбъектаМетаданныхДляРедактораMonaco.Comment.КонецЕсли;.Description=EndIf;
