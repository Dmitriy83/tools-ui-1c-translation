Method.ВычислитьВБезопасномРежиме.Comment.Для\ Каждого\ ИмяРазделителя\ Из\ МассивРазделителей\ Цикл\nУстановитьБезопасныйРежимРазделенияДанных(ИмяРазделителя,\ Истина);\nКонецЦикла;.Description=For Each SeparatorName In SeparatorsArray Do\nSetDataSeparationSafeMode(SeparatorName, True);\nEndDo;
Method.ВычислитьВБезопасномРежиме.Comment.Если\ ПодсистемаСуществует("ТехнологияСервиса\.БазоваяФункциональность")\ Тогда\nМодульРаботаВМоделиСервиса\ \=\ ОбщийМодуль("РаботаВМоделиСервиса");\nМассивРазделителей\ \=\ МодульРаботаВМоделиСервиса\.РазделителиКонфигурации();\nИначе\nМассивРазделителей\ \=\ Новый\ Массив;\nКонецЕсли;.Description=If SubsystemExists("CloudTechnology.Core") Then\nServiceModeModule \= CommonModule("WorkInServiceModel");\nSeparatorsArray \= ServiceModeModule.ConfigurationSeparators();\nElse\nSeparatorsArray \= New Array;\nEndIf;
Method.ВычислитьВБезопасномРежиме.Description=Evaluates the passed expression, presetting the safe mode of code execution\nand the safe mode of data separation for all separators present in the configuration.
Method.ВычислитьВБезопасномРежиме.Example.Description=Example 1\nParameters \= New Structure;\nParameters.Insert("Value1", 1);\nParameters.Insert("Value2", 10);\nResult \= Common.ExecuteInSafeMode("Parameters.Value1 \= Parameters.Value2", Parameters);\nExample 2\nResult \= Common.ExecuteInSafeMode("StandardSubsystemsServer.LibraryVersion()");
Method.ВычислитьВБезопасномРежиме.Name=ExecuteInSafeMode
Method.ВычислитьВБезопасномРежиме.Param.Выражение.Description=expression in 1C\:Enterprise built-in language.
Method.ВычислитьВБезопасномРежиме.Param.Выражение.Name=Expression
Method.ВычислитьВБезопасномРежиме.Param.ПараметрыМетода.Description=context required for evaluating the expression.\nIn the expression text, the context must be addressed by the name "Parameters".\nFor example, the expression "Parameters.Value1 \= Parameters.Value2" addresses the values\n"Value1" and "Value2" passed in Parameters as properties.
Method.ВычислитьВБезопасномРежиме.Param.ПараметрыМетода.Name=MethodParameters
Method.ВычислитьВБезопасномРежиме.Return.Description=result of expression evaluation.
